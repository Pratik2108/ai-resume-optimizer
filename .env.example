# Copy this file to .env and fill in your keys, then restart the app.
# cp .env.example .env

# ── Google Gemini ─────────────────────────────────────────
# Free tier available. Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OpenAI / ChatGPT ──────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── xAI / Grok ────────────────────────────────────────────
# Get key: https://console.x.ai
XAI_API_KEY=

# ── Ollama (local — no key needed) ────────────────────────
# Install: https://ollama.com  then run: ollama serve && ollama pull mistral
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=mistral

# ── Model overrides (optional) ────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini
# GROK_MODEL=grok-3-beta

# ── Logging ───────────────────────────────────────────────
# LOG_LEVEL=INFO
